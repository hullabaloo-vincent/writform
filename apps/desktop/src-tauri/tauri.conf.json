{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WritForm",
  "version": "0.1.0",
  "identifier": "com.writform.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WritForm",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5OEQwQ0U4MzZCRThFNzQKUldSMGpyNDI2QXlONlFBcDZuVU8vTHhQNno2Z1BORXJ0eFUyR0tRSnRveitrbjVtVmVVbWpGejMK",
      "endpoints": [
        "https://github.com/hullabaloo-vincent/writform/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  },
  "mainBinaryName": "writform-desktop"
}